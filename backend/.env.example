# ── Copy to .env and fill in your values ──────────────────────────────────────

# Database (Railway provides this automatically as $DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/nobel

# Auth — generate a strong key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-real-secret-key-at-least-32-chars

# CORS — your frontend URL(s), comma-separated
ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# Environment
ENVIRONMENT=production

# LLM
OPENAI_API_KEY=test
LLM_BASE_URL=https://vjioo4r1vyvcozuj.us-east-2.aws.endpoints.huggingface.cloud/v1
LLM_MODEL=openai/gpt-oss-120b
